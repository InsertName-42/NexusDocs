@model NexusDocs.Models.PublicPageViewModel

    @if (ViewBag.SyncError != null)
    {
        <div class="alert alert-warning">
            @ViewBag.SyncError
        </div>
    }

<article class="page-content">
    <h1>@Model.PageTitle</h1>
    <hr />
    <partial name="_PageTags" model='(Model, "Top")' />

    <div class="doc-body">
        @if (string.IsNullOrEmpty(Model.Content))
            {
                <p class="text-muted"><em>No content found. Please refresh to try syncing again.</em></p>
            }
            else
            {
                @Html.Raw(Model.Content)
            }
        </div>
    <partial name="_PageTags" model='(Model, "Bottom")' />
</article>

@if (Model.Interactions.Any())
{
    <section class="interactions mt-5">
        <h4>Page Actions</h4>
        @foreach (var interaction in Model.Interactions)
        {
            <div class="interaction-item" data-key="@interaction.ElementKey">
                <span>@interaction.InteractionType: @interaction.Value</span>
            </div>
        }
    </section>
}