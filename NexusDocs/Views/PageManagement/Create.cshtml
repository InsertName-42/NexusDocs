@model NexusDocs.Models.PageEntity

@{
    ViewData["Title"] = "Add New Page";
}

<h1>Add Page to Site</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <input type="hidden" asp-for="SiteId" />

            <div class="form-group mb-3">
                <label asp-for="PageTitle" class="control-label">Page Title</label>
                <input asp-for="PageTitle" class="form-control" placeholder="e.g. Chapter One" />
                <span asp-validation-for="PageTitle" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Slug" class="control-label">URL Slug</label>
                <input asp-for="Slug" class="form-control" placeholder="e.g. chapter-1" />
                <span asp-validation-for="Slug" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="GoogleDocId" class="control-label">Google Doc ID</label>
                <input asp-for="GoogleDocId" class="form-control" placeholder="The long ID from your Google Doc URL" />
                <small class="text-muted">Between d/ and /edit. Example: 1ABC...xyz</small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SortOrder" class="control-label">Sort Order</label>
                <input asp-for="SortOrder" type="number" class="form-control" value="1" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success">Save Page</button>
                <a asp-action="Index" asp-route-siteId="@Model.SiteId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>