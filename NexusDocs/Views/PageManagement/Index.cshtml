@model NexusDocs.Models.SiteEntity
@{
    ViewData["Title"] = "Manage Pages";
    var userKey = Model.User?.UserKey ?? "unknown";
}

<h2>Managing Pages for: @Model.SiteTitle</h2>
@{
    var expiredPages = Model.Pages.Where(p => p.EventDate.HasValue && p.EventDate < DateTime.Now).ToList();
}
<p>
    @if (expiredPages.Any())
    {
        <div class="alert alert-info border-info shadow-sm">
            <h5><i class="bi bi-info-circle"></i> Update Reminders</h5>
            <p>The following gift events have passed. You may want to update these pages:</p>
            <ul>
                @foreach (var ep in expiredPages)
                {
                    <li><strong>@ep.PageTitle</strong> (Event was on @ep.EventDate?.ToShortDateString())</li>
                }
            </ul>
        </div>
    }
    <a asp-action="Create" asp-route-siteId="@Model.SiteEntityId" class="btn btn-success">
        + Add New Page (Link Google Doc)
    </a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Slug</th>
            <th>Google Doc ID</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sitePage in Model.Pages.OrderBy(p => p.SortOrder))
        {
            <tr>
                <td>@sitePage.PageTitle</td>
                <td><code>/@userKey/@sitePage.Slug</code></td>
                <td><small class="text-muted">@sitePage.GoogleDocId</small></td>
                <td>
                    <a href="/@userKey/@sitePage.Slug" target="_blank" class="btn btn-sm btn-outline-primary">View</a>
                    <a asp-action="Edit" asp-route-id="@sitePage.PageEntityId" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@sitePage.PageEntityId" method="post"
                          onsubmit="return confirm('Are you sure you want to delete this page?');" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>